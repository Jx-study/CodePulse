[Unit]
Description=CodePulse Flask Backend
After=postgresql.service

[Service]
User=codepulse
WorkingDirectory=/home/codepulse/projects/CodePulse/backend
Environment=SANDBOX_SIDECAR_URL=http://127.0.0.1:8080
ExecStartPre=/home/codepulse/projects/CodePulse/backend/deploy-sidecar.sh
ExecStart=/home/codepulse/projects/CodePulse/backend/venv/bin/gunicorn \
    -w 1 --threads 10 --worker-class gthread --timeout 120 -b 127.0.0.1:5000 app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
