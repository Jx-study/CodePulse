# CodePulse Backend Scripts
# Usage: just <recipe>
# Install just: winget install Casey.Just

set windows-shell := ["cmd", "/c"]

# ── Dev ────────────────────────────────────────────────────────────────────
dev:
    just sandbox-build
    docker compose up postgres backend --build -d

# ── Sandbox ────────────────────────────────────────────────────────────────
sandbox-build:
    docker build -t codepulse-sandbox -f docker/Dockerfile .

# ── Migration ──────────────────────────────────────────────────────────────
migrate msg:
    docker compose exec backend flask db migrate -m "{{msg}}"

upgrade:
    docker compose exec backend flask db upgrade

downgrade:
    docker compose exec backend flask db downgrade

# ── DB Utils ───────────────────────────────────────────────────────────────
db-shell:
    docker compose exec postgres psql -U codepulse -d codepulse

db-tables:
    docker compose exec postgres psql -U codepulse -d codepulse -c "\dt"

db-reset:
    docker compose down -v
    docker compose up postgres -d
    docker compose up backend -d
    just upgrade

# ── Logs ───────────────────────────────────────────────────────────────────
logs:
    docker-compose logs -f backend

# ── Test ───────────────────────────────────────────────────────────────────
install:
    pip install -r requirements.txt pytest

test:
    pytest tests/ -v

test-file file:
    pytest {{file}} -v

# ── Seed ───────────────────────────────────────────────────────────────────
seed-tutorials:
    docker compose exec backend python seeds/seed_tutorials.py

seed-questions:
    docker compose exec backend python seeds/seed_questions.py

seed-questions-slug slug:
    docker compose exec backend python seeds/seed_questions.py {{slug}}

seed-all:
    docker compose exec backend python seeds/seed_tutorials.py
    docker compose exec backend python seeds/seed_questions.py

# ── Health ─────────────────────────────────────────────────────────────────
health:
    curl -s http://localhost:5000/api/health
