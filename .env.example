# PostgreSQL (Docker)
DB_PASSWORD=your_db_password
DATABASE_URL=postgresql://codepulse:${DB_PASSWORD}@postgres:5432/codepulse

# Mail
MAIL_SERVER=mailserver
MAIL_PORT=your_mail_server_port
MAIL_USE_SSL=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# Flask
SECRET_KEY=your_secret_key_here
SECURITY_PASSWORD_SALT=your_security_password_salt_here
FLASK_ENV=development
DEBUG=True
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Frontend URL (for OAuth callback redirect)
FRONTEND_URL=http://localhost:5173

# Backend URL (for OAuth redirect_uri)
BACKEND_URL=http://localhost:5000

# Vite: backend URL for Google OAuth redirect (browser-accessible, not Docker internal)
VITE_BACKEND_URL=http://localhost:5000

# OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
