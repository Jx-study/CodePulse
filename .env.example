# PostgreSQL (Docker)
DATABASE_URL=postgresql://<user>:<password>@postgres:5432/<dbname>

# Mail
MAIL_SERVER=mailserver
MAIL_PORT=your_mail_server_port
MAIL_USE_SSL=True

MAIL_USERNAME=your_mail
MAIL_PASSWORD=your_mail_app_password

# Flask
SECRET_KEY=your_secret_key_here
FLASK_ENV=development
DEBUG=True

# OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Backend URL (for OAuth redirect_uri, default: http://localhost:5000)
BACKEND_URL=http://localhost:5000

# Frontend URL (for OAuth callback redirect, default: http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# Vite: backend URL for Google OAuth redirect (browser-accessible, not Docker internal)
VITE_BACKEND_URL=http://localhost:5000